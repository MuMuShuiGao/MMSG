# 记忆后端选择。可选: builtin
MEMORY_BACKEND=builtin

# Pick one provider. OpenAI-compatible: works with OpenAI / DeepSeek / vLLM / Ollama (/v1).
OPENAI_MODEL=deepseek-v4-pro
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://aigw.netease.com/v1
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_BASE_URL=http://localhost:11434/v1

# QQBot channel (optional). Set both to enable.
# QQBOT_APP_ID=your_app_id
# QQBOT_SECRET=your_client_secret
